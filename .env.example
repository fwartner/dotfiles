# Machine-local environment variables
#
# Copy this file to ~/.env.local on a new machine and fill in real values.
# ~/.env.local is gitignored and sourced by stow/zsh/.zsh.d/exports.zsh.
#
#   cp .env.example ~/.env.local
#   chmod 600 ~/.env.local
#   $EDITOR ~/.env.local
#
# Format: KEY="value"  (one per line, no `export` prefix needed — exports.zsh
# re-exports anything it knows about)

# Fastlane (iOS/Android automation)
# Get an app-specific password from https://appleid.apple.com -> Sign-in & Security -> App-Specific Passwords
FASTLANE_USER="your.apple.id@example.com"
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Add other secrets here as needed (cloud provider tokens, API keys, etc.)
# OPENAI_API_KEY=""
# GH_TOKEN=""
